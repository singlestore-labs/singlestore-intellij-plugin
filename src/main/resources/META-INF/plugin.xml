<idea-plugin>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.ultimate</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="SingleStore SQL"
                  language="SingleStore SQL"
                  implementationClass="com.singlestore.intellij.lsp.SingleStoreSqlFileType"
                  fieldName="INSTANCE"
                  patterns="*.s2db.sql"/>
        <applicationConfigurable
                id="com.singlestore.intellij.settings"
                displayName="SingleStore Language Server"
                parentId="tools"
                instance="com.singlestore.intellij.settings.SingleStoreLspConfigurable"/>
        <platform.lsp.serverSupportProvider
                implementation="com.singlestore.intellij.lsp.SingleStoreLspServerSupportProvider"/>
    </extensions>
</idea-plugin>
